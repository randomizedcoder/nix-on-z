--- a/packaging/installer/install.in
+++ b/packaging/installer/install.in
@@ -24,6 +24,31 @@
 }

 case "$(uname -s).$(uname -m)" in
+    # --- Tier 1: native builds on Hydra ---
     Linux.x86_64)
         hash=@tarballHash_x86_64-linux@
         path=@tarballPath_x86_64-linux@
@@ -52,6 +57,37 @@
         path=@tarballPath_riscv64-linux@
         system=riscv64-linux
         ;;
+    # --- Tier 2: cross-compiled from x86_64-linux ---
+    # These platforms have working Nix builds but no native Hydra builders.
+    # Tarballs are cross-compiled from x86_64-linux.
+    Linux.s390x)
+        hash=@tarballHash_s390x-linux@
+        path=@tarballPath_s390x-linux@
+        system=s390x-linux
+        ;;
+    Linux.ppc64le)
+        hash=@tarballHash_powerpc64le-linux@
+        path=@tarballPath_powerpc64le-linux@
+        system=powerpc64le-linux
+        ;;
+    Linux.ppc64)
+        hash=@tarballHash_powerpc64-linux@
+        path=@tarballPath_powerpc64-linux@
+        system=powerpc64-linux
+        ;;
+    Linux.loongarch64)
+        hash=@tarballHash_loongarch64-linux@
+        path=@tarballPath_loongarch64-linux@
+        system=loongarch64-linux
+        ;;
+    Linux.mips64)
+        hash=@tarballHash_mips64el-linux@
+        path=@tarballPath_mips64el-linux@
+        system=mips64el-linux
+        ;;
+    Linux.riscv32)
+        hash=@tarballHash_riscv32-linux@
+        path=@tarballPath_riscv32-linux@
+        system=riscv32-linux
+        ;;
     Darwin.x86_64)
         hash=@tarballHash_x86_64-darwin@
         path=@tarballPath_x86_64-darwin@
