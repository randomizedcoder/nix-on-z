 source common.sh
 # This test is run by `tests/functional/nested-sandboxing/runner.nix` in an extra layer of sandboxing.
-[[ -d /nix/store ]] || skipTest "running this test without Nix's deps being drawn from /nix/store is not yet supported"
+#
+# The test builds derivations recursively at multiple nesting levels, each
+# inside its own sandbox.  This requires:
+#
+# 1. /nix/store must exist AND be populated with Nix's runtime dependencies
+#    (bash, coreutils, etc.) so that the builder shell path from config.nix
+#    resolves inside the chroot.
+#
+# 2. The builder shell in config.nix must be reachable inside the sandbox.
+#    On NixOS, config.nix points to /nix/store/.../bash which gets mounted
+#    via --extra-sandbox-paths.  On non-NixOS systems, config.nix points to
+#    /usr/bin/bash which does NOT exist inside the chroot (only /bin/sh from
+#    the sandbox-shell is available).
+#
+# When Nix is built from source (not installed via nixpkgs), these conditions
+# are not met and the test cannot work.  The original check only tested for
+# directory existence, not actual content.
+if [[ ! -d /nix/store ]] || [[ -z "$(ls -A /nix/store 2>/dev/null)" ]]; then
+    skipTest "nested sandboxing requires a populated /nix/store with Nix's runtime dependencies"
+fi
 
