+        /* Try to find bashInteractive from nixpkgs for a better shell
+           experience.  However, only attempt this when the installable
+           is a flake — in that case we can extract the nixpkgs input
+           from the flake's lock file.
+
+           When the user passes -f/--file (non-flake mode), the
+           installable is an InstallableAttrPath and we have no flake
+           lock file to get nixpkgs from.  Falling back to
+           defaultNixpkgsFlakeRef() ("flake:nixpkgs") would attempt a
+           flake registry lookup, which (a) fails when tests use an
+           isolated empty registry and (b) is conceptually wrong since
+           the user explicitly chose file mode.  The silent catch at
+           the end masks this failure but leaves the build environment
+           in a broken state where structured attrs variables ($out,
+           $outputs) are empty.
+
+           By skipping the lookup entirely for non-flake installables
+           we avoid the spurious registry access and fall back cleanly
+           to the system "bash". */
+        if (auto * flakeInstallable = dynamic_cast<const InstallableFlake *>(&*installable)) {
+            try {
+                auto state = getEvalState();
+
+                auto nixpkgsLockFlags = lockFlags;
+                nixpkgsLockFlags.inputOverrides = {};
+                nixpkgsLockFlags.inputUpdates = {};
+
+                auto nixpkgs = flakeInstallable->nixpkgsFlakeRef();
+
+                auto bashInstallable = make_ref<InstallableFlake>(
+                    nullptr, //< Don't barf when the command is run with --arg/--argstr
+                    state,
+                    std::move(nixpkgs),
+                    "bashInteractive",
+                    ExtendedOutputsSpec::Default(),
+                    Strings{},
+                    Strings{"legacyPackages." + settings.thisSystem.get() + "."},
+                    nixpkgsLockFlags);
+
+                for (auto & path : Installable::toStorePathSet(
+                         getEvalStore(), store, Realise::Outputs, OperateOn::Output, {bashInstallable})) {
+                    auto s = store->printStorePath(path) + "/bin/bash";
+                    if (pathExists(s)) {
+                        shell = s;
+                        foundInteractive = true;
+                        break;
+                    }
                 }
-            }

-            if (!foundInteractive)
-                throw Error("package 'nixpkgs#bashInteractive' does not provide a 'bin/bash'");
+                if (!foundInteractive)
+                    throw Error("package 'nixpkgs#bashInteractive' does not provide a 'bin/bash'");

-        } catch (Error &) {
-            ignoreExceptionExceptInterrupt();
+            } catch (Error &) {
+                ignoreExceptionExceptInterrupt();
+            }
